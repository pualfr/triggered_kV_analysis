type: software
title: "Retrospective triggered kV image analysis workflow"
version: 1.0.0
license: BSD-3-Clause
authors:
  - family-names: "Techer"
    given-names: "Quentin"
  - family-names: "Grandgirard"
    given-names: "Noé"
  - family-names: "Sandjong"
    given-names: "Saturnin"
  - family-names: "Marchesi"
